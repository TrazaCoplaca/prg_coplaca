<Window x:Class="PaginaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfEmbarques"
        xmlns:controls="clr-namespace:WpfEmbarques"
        mc:Ignorable="d"
        Title="Sistema de Embarques" 
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#1E1E2F">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="183*"/>
            <ColumnDefinition Width="65*"/>
            <ColumnDefinition Width="552*"/>
        </Grid.ColumnDefinitions>
        <Image Source="Images/Coplaca Apilado.png"
               Stretch="Fill"
               Panel.ZIndex="0" Grid.ColumnSpan="3"/>
        <Grid Grid.ColumnSpan="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="209*" />
                <ColumnDefinition Width="91*" />
            </Grid.ColumnDefinitions>

            <controls:LoadingOverlay x:Name="OverlayCargando" />
            <!-- 📋 Panel lateral -->
            <StackPanel Grid.Column="0"
                    Background="ForestGreen"
                    Orientation="Vertical"
                    Panel.ZIndex="1">

                <TextBlock Text="Menú"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       Margin="10"
                       HorizontalAlignment="Center" />
                <Button Content="Inicio"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Button_Click_2" />

                <Button Content="Embarques"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Button_Click" />

                <Button Content="Usuarios"
                    Style="{StaticResource MenuButtonStyle}"
                    Click="Button_Click_1" />
                <Button Content="Configuración"
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="Button_Click_3"/>
                <Button Content="Cambiar Usuario"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Button_Click_4" />
                <Button Content="Test de Conexion"
                        Style="{StaticResource MenuButtonStyle}"
                        Click="Button_Click_5" />
            </StackPanel>

            <!-- 🧱 Zona principal de contenido -->
            <Grid Grid.Column="1"
              Background="#F5F5F5"
              Grid.ColumnSpan="2"
              Panel.ZIndex="1">

                <ContentControl x:Name="MainContentControl" />
            </Grid>
        </Grid>
    </Grid>
</Window>
