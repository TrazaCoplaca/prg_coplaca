<UserControl x:Class="UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfEmbarques"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White">

    <DockPanel Margin="10">
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    Margin="0,0,0,10">
            <Button x:Name="BtnAdd"
                    Style="{StaticResource BotonAnadir}"
                    Click="BtnAdd_Click"/>
                   
            <Button x:Name="btnEdit"
                    Visibility="Collapsed"
                    Style="{StaticResource BotonEditar}" />
            <Button x:Name="BtnDelete"
                    Visibility="Collapsed"
                    Style="{StaticResource BotonBorrar}" />


        </StackPanel>
        <DataGrid x:Name="dataGridUsuarios"
                  Style="{StaticResource EstiloGridModerno}"
                  Grid.Row="1"
                  d:ItemsSource="{d:SampleData ItemCount=5}"
                  Background="White"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Usuario"
                                    Binding="{Binding id_usu}"
                                    Width="150" />
                <DataGridTextColumn Header="Nombre"
                                    Binding="{Binding des_usu}"
                                    Width="*" />
                <DataGridTextColumn Header="Cooperativa"
                                    Binding="{Binding coop_usu}"
                                    Width="100" />
                <DataGridTextColumn Header="Nivel"
                                    Binding="{Binding niv_usu}"
                                    Width="100" />
                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Width="30"
                                        Height="30"
                                        Margin="5"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Editar usuario"
                                        Click="btnEdit_Click">
                                    <TextBlock Text="✏️"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center" 
                                               Foreground="Blue"/>
                                </Button>

                                <!-- Botón Borrar -->
                                <Button Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Borrar usuario"
                                        Click="BtnDelete_Click">
                                    <TextBlock Text="🗑"
                                               FontSize="16"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="red"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            
        </DataGrid>

    </DockPanel>
</UserControl>
