<Window x:Class="EditarDatoInteresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Editar Datos Adicionales"
        Height="300" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid >
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="29*"/>
            <ColumnDefinition Width="91*"/>
            <ColumnDefinition Width="30*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,5,0,5" Grid.ColumnSpan="3">
            <Label Content="Producto" 
                   Style="{StaticResource LabelGeneral}"/>
            <TextBox x:Name="TxtProducto"
              Style="{StaticResource CajaTexto}"
              Margin="0,5" />
            <Label Content="Termógrafo" 
                   Style="{StaticResource LabelGeneral}"/>
            <TextBox x:Name="TxtTermografo"
              Style="{StaticResource CajaTexto}"
              Margin="0,5" />
            <Label Content="Temperatura" 
                   Style="{StaticResource LabelGeneral}"/>
            <TextBox x:Name="TxtTemperatura"
              Style="{StaticResource CajaTexto}"
                     
              Margin="0,5" Width="83" HorizontalAlignment="Left" />
        </StackPanel>
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3">
            <Button Content="Acpetar"  
             Style="{StaticResource BotonPrincipal}"
                    Margin="0,5"
                    Click="BtnGuardar_Click"/>
        </StackPanel>

    </Grid>



</Window>

