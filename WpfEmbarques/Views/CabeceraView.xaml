<UserControl x:Class="CabeceraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WpfEmbarques"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   
    
    <DockPanel Margin="10">
        <!-- Botones de acción -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Top"
                    Margin="0,0,0,10">
            <Button x:Name="BtnAdd"
                    Style="{StaticResource BotonAnadir}"
                    Click="BtnAdd_Click" />
            <Button x:Name="BtnEdit"
                    Style="{StaticResource BotonEditar}"
                    Visibility="Collapsed"
                    Click="BtnEdit_Click" />
            <Button x:Name="BtnDelete"
                    Style="{StaticResource BotonBorrar}"
                    Visibility="Collapsed"
                    Click="BtnDelete_Click" />
        </StackPanel>

        <!-- Tabla de cabeceras -->
        <DataGrid x:Name="dataGridCabeceras"
                  Style="{StaticResource EstiloGridModerno}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  Background="White">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Embarque"
                                    Binding="{Binding idVale_cva}"
                                    Width="80" />
                <DataGridTextColumn Header="Coop"
                                    Binding="{Binding idCoop_cva}"
                                    Width="80" />
                <DataGridTextColumn Header="Empa"
                                    Binding="{Binding idEmpa_cva}"
                                    Width="80" />
                <DataGridTextColumn Header="Sem"
                                    Binding="{Binding Sem_cva}"
                                    Width="40" />
                <DataGridTextColumn Header="Ord"
                                    Binding="{Binding SemEmb_cva}"
                                    Width="40" />
                <DataGridTextColumn Header="Fecha"
                                    Binding="{Binding Fecha_cva, StringFormat='dd/MM/yyyy'}"
                                    Width="120" />
                <DataGridTextColumn Header="Matrícula"
                                    Binding="{Binding Matr_cva}"
                                    Width="120" />
                <DataGridTextColumn Header="Transportista"
                                    Binding="{Binding Des_trans}"
                                    Width="200" />
                <DataGridTextColumn Header="Observaciones"
                                    Binding="{Binding Observaciones_cva}"
                                    Width="*"/>

                <DataGridTemplateColumn Header="Acciones">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center">
                                <Button Width="30"
                                        Height="30"
                                        Margin="5"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Editar cabecera"
                                        Click="BtnEdit_Click">
                                    <TextBlock Text="✏️"
                                               FontSize="16"
                                               Foreground="Blue" />
                                </Button>

                                <Button Width="30"
                                        Height="30"
                                        Margin="2"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Borrar cabecera"
                                        Click="BtnDelete_Click">
                                    <TextBlock Text="🗑"
                                               FontSize="16"
                                               Foreground="Red" />
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
