<Window x:Class="DatosDeInteresView"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
         xmlns:local="clr-namespace:WpfEmbarques"
         mc:Ignorable="d"
         Title="Datos de Interes"
         Height="450" Width="800"
 
         WindowStartupLocation="CenterScreen"
         ResizeMode="NoResize">

    <DockPanel Height="394" VerticalAlignment="Top">


        <!-- CONTENIDO PRINCIPAL -->

        <StackPanel Margin="10"
                        VerticalAlignment="Top">

            <!-- GRID DE LÍNEAS CON ESTILO PERSONALIZADO -->
            <Grid Margin="0,20,0,0">
                <GroupBox Header="Datos de Interés"
                              FontSize="16"
                              FontWeight="Bold"
                              BorderBrush="DarkGreen"
                              BorderThickness="1"
                              Margin="10"
                              Padding="10">
                    <DockPanel LastChildFill="True">
                        <DataGrid x:Name="dataGridLineas"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="True"
                                      IsReadOnly="True"
                                      SelectionMode="Extended"
                                      Margin="0,0,0,10"
                                      Height="244"
                                      Style="{StaticResource EstiloGridModerno}"
                                      ItemsSource="{Binding Lineas}"
                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="#DCDCDC"
                                      VerticalGridLinesBrush="#DCDCDC">

                            <DataGrid.Resources>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="BorderBrush" Value="#D0D0D0" />
                                    <Setter Property="BorderThickness" Value="0.5" />
                                    <Setter Property="Padding" Value="6,2" />
                                    <Setter Property="FontSize" Value="14" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="Black" />
                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#A5D6A7" />
                                            <Setter Property="Foreground" Value="Black" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.Resources>

                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID Línea"
                                                        Binding="{Binding Nlin_din}"
                                                        Visibility="Collapsed" />
                                <DataGridTextColumn Header="Producto"
                                                        Binding="{Binding Producto_din}"
                                                        Width="200" />
                                <DataGridTextColumn Header="Termógrafo"
                                                        Binding="{Binding Termografo_din}"
                                                        Width="*" />
                                <DataGridTextColumn Header="Temperatura"
                                                        Binding="{Binding Temp_din}"
                                                        Width="200">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextAlignment" Value="Right" />
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Acciones"
                                                            Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal"
                                                            HorizontalAlignment="Center">
                                                <Button Content="✏️"
                                                            Width="30"
                                                            Height="30"
                                                            Margin="0,0,5,0"
                                                            Style="{StaticResource BotonEditar}"
                                                            Click="BtnEditarLinea_Click" />
                                                <Button Content="🗑"
                                                            Width="30"
                                                            Height="30"
                                                            Style="{StaticResource BotonBorrar}"
                                                            Click="BtnEliminarLinea_Click" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </GroupBox>
            </Grid>
            <Button Content="➕"
                    FontSize="20" 
                    Style="{StaticResource BotonAnadir}"
                    Foreground="ForestGreen" Width="41"
                    HorizontalAlignment="Right" Click="Button_Click"/>

        </StackPanel>

    </DockPanel>
</Window>

