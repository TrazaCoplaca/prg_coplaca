<Window x:Class="CabeceraWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfEmbarques"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        Title="Embarques"
        Height="768"
        Width="1024"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="White"
        FontSize="12">

    <Window.Resources>
        <Style x:Key="BotonGrabar"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Green" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Padding"
                    Value="10,5" />
            <Setter Property="Margin"
                    Value="5" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <Style x:Key="BotonCancelar"
               TargetType="Button">
            <Setter Property="Background"
                    Value="Red" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Padding"
                    Value="10,5" />
            <Setter Property="Margin"
                    Value="5" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>

        <Style x:Key="BotonSecundario"
               TargetType="Button">
            <Setter Property="Background"
                    Value="DarkGray" />
            <Setter Property="Foreground"
                    Value="White" />
            <Setter Property="FontWeight"
                    Value="Bold" />
            <Setter Property="Padding"
                    Value="5" />
            <Setter Property="Cursor"
                    Value="Hand" />
        </Style>
        <ObjectDataProvider x:Key="ProductosSource"
                            ObjectType="{x:Type local:ProductoService}"
                            MethodName="ObtenerProductos" />
        <ObjectDataProvider x:Key="TipoPaletSource"
                            ObjectType="{x:Type local:ServicioGlobal}"
                            MethodName="ObtenerTipoPalet" />
        <ObjectDataProvider x:Key="TipoCajaSource"
                            ObjectType="{x:Type local:ServicioGlobal}"
                            MethodName="ObtenerTipoCaja" />
        <ObjectDataProvider x:Key="ListaTransportista"
                            ObjectType="{x:Type local:ServicioGlobal}"
                            MethodName="ObtenerTrnasportista" />
    </Window.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0"
                    Grid.Row="0"
                    Orientation="Horizontal">
            <Button Content="🖨️"
                    ToolTip="Imprimir"
                    Style="{StaticResource BotonPrincipal}"
                    Click="BtnImprimir_Click"
                    Margin="0,0,0,0"
                    Width="50" />
        </StackPanel>
        <StackPanel Grid.Column="1"
                    Grid.Row="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="103,5,0,5"
                    Width="104">
            <Button Content="✔️"
                    Style="{StaticResource BotonGrabar}"
                    Click="BtnGuardar_Click"
                    Height="35"
                    Width="41" />
            <Button Content="❌"
                    Style="{StaticResource BotonCancelar}"
                    Click="BtnCancelar_Click"
                    Height="38"
                    HorizontalAlignment="Right" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Margin="1,0,0,0"
                      Grid.ColumnSpan="5"
                      Grid.Column="2"
                      HorizontalAlignment="Left"
                      Width="Auto">
            <GroupBox Header="Cabecera de Embarque"
                      FontSize="18"
                      FontWeight="Bold"
                      Foreground="DarkGreen"
                      BorderBrush="DarkGreen"
                      BorderThickness="2"
                      Margin="1,1,1,1"
                      Padding="5,5,5,5"
                      Width="Auto"
                      Height="691">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35*" />
                            <RowDefinition Height="34*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*" />
                            <ColumnDefinition Width="60*" />
                            <ColumnDefinition Width="25*" />
                            <ColumnDefinition Width="20*" />
                            <ColumnDefinition Width="30*" />
                            <ColumnDefinition Width="10*" />
                            <ColumnDefinition Width="65*" />
                            <ColumnDefinition Width="65*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical"
                                    Grid.RowSpan="2">
                            <Label Content="Nº Embarque"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"
                                   FontSize="12" />
                            <TextBox x:Name="txtId"
                                     Style="{StaticResource CajaTexto}"
                                     Margin="0,0,10,0" />

                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    Grid.RowSpan="2">
                            <Label Content="Fecha"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <DatePicker x:Name="dpFecha"
                                        SelectedDateFormat="Short"
                                        Language="es-ES"
                                        Style="{StaticResource CajaDatePicker}"
                                        Margin="0,0,10,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical">
                            <Label Content="Semana"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <TextBox x:Name="txtSemana"
                                     Style="{StaticResource CajaTexto}"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Center"
                                     Margin="0,0,10,0" />

                        </StackPanel>
                        <StackPanel Grid.Column="3"
                                    Orientation="Vertical">
                            <Label Content="Orden"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <TextBox x:Name="TxtOrden"
                                     Style="{StaticResource CajaTexto}"
                                     IsReadOnly="True"
                                     HorizontalContentAlignment="Center"
                                     Margin="0,0,10,0" />

                        </StackPanel>

                        <StackPanel Grid.Column="4"
                                    Orientation="Vertical">

                            <Label Content="Orden Carga"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"
                                   HorizontalAlignment="Left" />
                            <TextBox x:Name="txtOrdCarga"
                                     Style="{StaticResource CajaTexto}"
                                     Margin="0,0,10,0" />

                        </StackPanel>
                        <StackPanel Grid.Column="5"
                                    Orientation="Horizontal">
                            <Button Content="🔍"
                                    ToolTip="Imprimir"
                                    Style="{StaticResource BotonPrincipal}"
                                    Click="CargarOrden_Click"
                                    Margin="0,0,0,0"
                                    HorizontalAlignment="Center" />


                        </StackPanel>

                        <StackPanel Grid.Column="6"
                                    Orientation="Vertical">

                            <Label Content="Matrícula Remolque"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <TextBox x:Name="txtMatricula"
                                     Style="{StaticResource CajaTexto}"
                                     Margin="0,0,10,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="7"
                                    Orientation="Vertical">

                            <Label Content="Matrícula Tractora"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <TextBox x:Name="txtMatTra"
                                     Style="{StaticResource CajaTexto}"
                                     Padding="8,0,8,0" />
                        </StackPanel>
                    </Grid>

                    <!-- FILA 1:  Termógrafo  -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="246*" />
                            <ColumnDefinition Width="152*" />
                            <ColumnDefinition Width="427*" />
                            
                        </Grid.ColumnDefinitions>


                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical" Margin="0,0,4,0">
                            <Label Content="Nº Termógrafo"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3" />
                            <TextBox x:Name="txtNterm"
                                     Style="{StaticResource CajaTexto}"
                                     Margin="0,0,10,0" />

                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical" Grid.ColumnSpan="2" Margin="0,0,263,0">
                            <Label Content="Temperatura Transporte"
                            Style="{StaticResource LabelGeneral}"
                            Padding="5,1,1,3" />
                            <TextBox x:Name="txtTemp"
                              Style="{StaticResource CajaTexto}"
                              PreviewTextInput="TxtTemp_PreviewTextInput"
                              DataObject.Pasting="TxtTemp_Pasting"
                              Margin="0,0,10,0" Width="172" HorizontalAlignment="Left" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical" Margin="0,0,4,0">
                            <Label Content="Transportista"
                            Style="{StaticResource LabelGeneral}"
                            Padding="5,1,1,3"/>
                            <ComboBox x:Name="cmbTransportista"
                               ItemsSource="{Binding ListaTransportista}"
                               DisplayMemberPath="Des_trans"
                               SelectedValuePath="id_trans"
                               Style="{StaticResource CajaComboRedondeado}" Width="Auto" />

                        </StackPanel>



                    </Grid>

                    <!-- FILA 2: Transportista / Cargador -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="13*" />
                            <ColumnDefinition Width="13*"/>

                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical"
                                    Margin="4,5,5,5">
                            <Label Content="Cargador"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"/>
                            <ComboBox x:Name="cmbCargador"
                                      DisplayMemberPath="Nomb_carg"
                                      SelectedValuePath="id_carg"
                                      ItemsSource="{Binding ListaCargador}"
                                      Style="{StaticResource CajaComboRedondeado}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                     Orientation="Vertical"
                                     Margin="5">
                             <Label Content="Naviera"
                                     Style="{StaticResource LabelGeneral}"
                                     Padding="5,1,1,3"/>
                             <ComboBox x:Name="cmbNaviera"
                                       DisplayMemberPath="Des_nav"
                                       SelectedValuePath="id_nav"
                                       ItemsSource="{Binding ListaNavieras}"
                                       Style="{StaticResource CajaComboRedondeado}" />
                        </StackPanel>

                    </Grid>

                    <!-- FILA 3: Naviera / Buque / Destino / Observaciones -->
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                       
                        <StackPanel Grid.Column="0"
                                    Orientation="Vertical"
                                    Margin="5">
                            <Label Content="Buque"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"/>
                            <ComboBox x:Name="cmbBuque"
                                      DisplayMemberPath="Des_buq"
                                      SelectedValuePath="id_buq"
                                      ItemsSource="{Binding ListaBuques}"
                                      Style="{StaticResource CajaComboRedondeado}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Vertical"
                                    Margin="5">
                            <Label Content="Muelle"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"/>
                            <ComboBox x:Name="cmbIsla"
                                      DisplayMemberPath="des_Isla"
                                      SelectedValuePath="id_Isla"
                                      ItemsSource="{Binding ListaIsla}"
                                      Style="{StaticResource CajaComboRedondeado}" />
                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Vertical"
                                    Margin="5">
                            <Label Content="Destino"
                                   Style="{StaticResource LabelGeneral}"
                                   Padding="5,1,1,3"/>
                            <ComboBox x:Name="cmbDestino"
                                      DisplayMemberPath="des_des"
                                      SelectedValuePath="id_des"
                                      ItemsSource="{Binding ListaDestino}"
                                      Style="{StaticResource CajaComboRedondeado}" />
                        </StackPanel>
                        <StackPanel Grid.Column="3"
                                    Orientation="Horizontal">
                             <CheckBox x:Name="chkFrutSemAnt"
                                      Content="Fruta Semana Anterior"
                                      Style="{StaticResource CheckBoxRedondeado}" />
                         </StackPanel>       
                    </Grid>

                    <!-- FILA 4: Palets, cajas plásticas y fruta anterior -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60*" />
                            <ColumnDefinition Width="60*" />
                            <ColumnDefinition Width="60*" />
                            <ColumnDefinition Width="30*" />


                        </Grid.ColumnDefinitions>
  
                        
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal" Grid.ColumnSpan="2" Margin="236,0,0,0">
                            <Button Content="📌 Datos Adicionales "
                                ToolTip="Datos de Interes"
                                Style="{StaticResource BotonPrincipal}"
                                Click="BtnDatosDeInteres"
                                Margin="0,0,0,0"
                                Cursor="Hand"
                                HorizontalAlignment="Center" />


                        </StackPanel>
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    Margin="5">
                        <Button Content="📝Observaciones "
                                    ToolTip="Observaciones"
                                    Style="{StaticResource BotonPrincipal}"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="BtnObservaciones_Click" />   
                        </StackPanel>

                    </Grid>
                    <Grid Grid.Row="6"
                          Margin="0,20,0,0">
                        <GroupBox Header="Líneas Embarques"
                                  FontSize="16"
                                  FontWeight="Bold"
                                  BorderBrush="DarkGreen"
                                  BorderThickness="1"
                                  Margin="10"
                                  Padding="10">
                            <DockPanel LastChildFill="True">
                                <Button Content="➕"
                                        DockPanel.Dock="Top"
                                        Width="24"
                                        Height="35"
                                        Style="{StaticResource BotonAnadir}"
                                        Click="BtnAddLinea_Click"
                                        RenderTransformOrigin="0.26,0.482"
                                        HorizontalAlignment="Left" />
                                <DataGrid x:Name="dataGridLineas"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="True"
                                          CanUserDeleteRows="True"
                                          IsReadOnly="True"
                                          SelectionMode="Extended"
                                          Margin="0,0,0,10"
                                          Height="244"
                                          Style="{StaticResource EstiloGridModerno}"
                                          ItemsSource="{Binding ListarLineas}"
                                          GridLinesVisibility="All"
                                          HorizontalGridLinesBrush="#DCDCDC"
                                          VerticalGridLinesBrush="#DCDCDC">

                                    <DataGrid.Resources>
                                        <Style TargetType="DataGridCell">

                                            <Setter Property="BorderBrush"
                                                    Value="#D0D0D0" />
                                            <!-- Gris claro -->
                                            <Setter Property="BorderThickness"
                                                    Value="0.5" />
                                            <Setter Property="Padding"
                                                    Value="6,2" />
                                            <Setter Property="FontSize"
                                                    Value="14" />
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Setter Property="Foreground"
                                                    Value="Black" />
                                            <Setter Property="HorizontalContentAlignment"
                                                    Value="Left" />
                                            <Setter Property="VerticalContentAlignment"
                                                    Value="Center" />
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected"
                                                         Value="True">
                                                    <Setter Property="Background"
                                                            Value="#A5D6A7" />
                                                    <Setter Property="Foreground"
                                                            Value="Black" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGrid.Resources>

                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="ID Línea"
                                                            Binding="{Binding idLinea_lva, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                            Visibility="Collapsed" />
                                        <DataGridTextColumn Header="Cod. Producto"
                                                            Binding="{Binding prod_lva}"
                                                            Width="100" />
                                        <DataGridTextColumn Header="Descripción"
                                                            Binding="{Binding desProd_lva}"
                                                            Width="*" />
                                        <DataGridTextColumn Header="Peso Neto"
                                                            Binding="{Binding pNeto_lva}"
                                                            Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment"
                                                            Value="Right" />
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Stretch" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Cajas"
                                                            Binding="{Binding cajas_lva}"
                                                            Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment"
                                                            Value="Right" />
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Stretch" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>

                                        <DataGridTextColumn Header="T.Caja"
                                                            Binding="{Binding desCaja_lva}"
                                                            Width="100" />
                                        <DataGridTextColumn Header="Total Kilos"
                                                            Binding="{Binding totkil_lva}"
                                                            Width="100">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment"
                                                            Value="Right" />
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Stretch" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Nº Palet"
                                                            Binding="{Binding nPalet_lva}"
                                                            Width="90">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="TextAlignment"
                                                            Value="Right" />
                                                    <Setter Property="HorizontalAlignment"
                                                            Value="Stretch" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="T.Palet"
                                                            Binding="{Binding desPalet_lva}"
                                                            Width="100" />
                                        <DataGridTemplateColumn Header="Acciones"
                                                                Width="100">

                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal"
                                                                HorizontalAlignment="Center">
                                                        <Button Content="✏️"
                                                                Width="30"
                                                                Height="30"
                                                                Margin="0,0,5,0"
                                                                Style="{StaticResource BotonSecundario}"
                                                                Click="BtnEditarLinea_Click" />
                                                        <Button Content="🗑"
                                                                Width="30"
                                                                Height="30"
                                                                Style="{StaticResource BotonCancelar}"
                                                                Click="BtnEliminarLinea_Click" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </DockPanel>
                        </GroupBox>
                    </Grid>
                </Grid>
            </GroupBox>
        </ScrollViewer>
    </Grid>
</Window>

