<Window x:Class="UsuarioWindowxaml"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfEmbarques"
        mc:Ignorable="d"
        Title="Usuario Embarques"
        Height="450"
        Width="535"
        WindowStartupLocation="CenterScreen"
        Background="White">

    <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Label Content="Usuario" />
                <TextBox x:Name="txtUsuario"
                         Style="{StaticResource CajaTexto}"
                         Margin="0,5" />

                <Label Content="Contraseña" />
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource Password}"
                             Margin="0,5" />
               
                <Label Content="Nombre" />
                <TextBox x:Name="txtDescripcion"
                     Style="{StaticResource CajaTexto}"
                     Margin="0,5" />

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Cooperativa" />
                    <TextBox x:Name="txtCoop"
                             Margin="0,5"
                             Style="{StaticResource CajaTexto}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Nivel" />
                    <ComboBox x:Name="cmbNivel"
                              Margin="0,5"
                              SelectedIndex="0"
                              Style="{StaticResource CajaComboRedondeado}">
                        <ComboBoxItem Content="1" />
                        <ComboBoxItem Content="2" />
                        <ComboBoxItem Content="3" />
                        
                    </ComboBox>
                </StackPanel>
            </Grid>
        </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">
                <Button x:Name="btnGrabar"
                    Style="{StaticResource BotonGrabar}"
                        Width="80"
                        Click="BtnGuardar_Click" />
                <Button x:Name="BtnCancelar"
                    Style="{StaticResource BotonCancelar}"
                        Width="80"
                        Margin="5"
                        Click="BtnCancelar_Click" />
            </StackPanel>
        </Grid>
</Window>
